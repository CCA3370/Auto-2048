{
  "name": "2048-autoplayer",
  "version": "1.0.0",
  "description": "2048 game with AutoPlayer using Expectimax algorithm",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run build:wasm && tsc && vite build",
    "build:app": "tsc && vite build",
    "build:wasm": "wasm-pack build wasm-autoplayer --target web --out-dir ../public/wasm-autoplayer --release",
    "preview": "vite preview",
    "test": "vitest run",
    "test:wasm": "cargo test --manifest-path wasm-autoplayer/Cargo.toml"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wasm-pack": "^0.14.0"
  }
}
